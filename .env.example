# ============================================
# ZERO DOWNTIME AI - Environment Configuration
# ============================================

# Backend
BACKEND_PORT=3001
NODE_ENV=development

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_PORT=8000

# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_AI_SERVICE_URL=http://localhost:8000

# Simulation
SIMULATION_INTERVAL_MS=3000
ANOMALY_INJECTION_PROBABILITY=0.05

# Database (optional - using in-memory store by default)
# MONGODB_URI=mongodb://localhost:27017/zero-downtime-ai
# FIREBASE_PROJECT_ID=your-project-id

# Logging
LOG_LEVEL=info
